<div class="cart-drawer" id="cart-drawer" aria-hidden="true">
  <div class="cart-drawer__overlay" onclick="closeCart()"></div>
  <div class="cart-drawer__panel">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">{{ 'cart.general.title' | t }} (<span id="drawer-count">{{ cart.item_count }}</span>)</h2>
      <button class="cart-drawer__close" onclick="closeCart()" aria-label="Close cart">✕</button>
    </div>
    <div class="cart-drawer__items" id="cart-drawer-items">
      {% render 'cart-items' %}
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__subtotal">
        <span>{{ 'cart.general.subtotal' | t }}</span>
        <span id="drawer-total">{{ cart.total_price | money }}</span>
      </div>
      <a href="/checkout" class="btn btn--primary btn--full">{{ 'cart.general.checkout' | t }}</a>
    </div>
  </div>
</div>
