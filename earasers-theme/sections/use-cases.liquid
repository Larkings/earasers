<section class="use-cases">
  <div class="container">
    <div class="use-cases__header">
      <h2 class="use-cases__heading" data-reveal>{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="use-cases__sub" data-reveal data-delay="1">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="use-cases__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'case' %}
            <a href="{{ block.settings.url }}" class="use-case-card" style="background: {{ block.settings.bg_color }};" {{ block.shopify_attributes }} data-reveal>
              {% if block.settings.image_url != blank %}
                <div class="use-case-card__img">
                  <img src="{{ block.settings.image_url }}" alt="{{ block.settings.title }}" width="130" height="130" loading="lazy">
                </div>
              {% endif %}
              <h3 class="use-case-card__title">{{ block.settings.title }}</h3>
              <p class="use-case-card__body">{{ block.settings.body }}</p>
              <div class="use-case-card__footer">
                <span class="use-case-card__product">{{ block.settings.product_name }}</span>
                <span class="use-case-card__cta">→</span>
              </div>
            </a>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Use cases",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made for your world"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Stage, studio, clinic or bedroom. We have the right fit."
    }
  ],
  "blocks": [
    {
      "type": "case",
      "name": "Use case",
      "settings": [
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Musician"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Description",
          "default": "On stage and in the studio."
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name",
          "default": "Music Earplugs"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Card background",
          "default": "#FDF0F0"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Use cases"
    }
  ]
}
{% endschema %}
