{% comment %}
  Layer 2 content for the Sleeping Earplugs product page.
  Referenced by templates/product.sleeping.json (to be created)
{% endcomment %}

<!-- TODO: klant levert main image aan voor Sleeping pagina -->

<section class="product-content product-content--sleeping">
  <div class="product-content__hero">
    <div class="container product-content__hero-inner">
      <div class="product-content__hero-text" data-reveal>
        {% if section.settings.badge != blank %}
          <p class="product-content__badge">{{ section.settings.badge }}</p>
        {% endif %}
        <h1 class="product-content__heading">{{ section.settings.heading }}</h1>
        <p class="product-content__sub">{{ section.settings.subheading }}</p>
        {% if section.settings.cta_label != blank %}
          <a href="{{ section.settings.cta_url }}" class="btn btn--primary">{{ section.settings.cta_label }}</a>
        {% endif %}
      </div>
      {% if section.settings.hero_image %}
        <div class="product-content__hero-img" data-reveal data-delay="1">
          <!-- TODO: klant levert main image aan voor Sleeping pagina -->
          <img src="{{ section.settings.hero_image | img_url: '500x' }}" alt="{{ section.settings.heading }}" loading="lazy">
        </div>
      {% endif %}
    </div>
  </div>

  <!-- Feature blocks -->
  <div class="container" style="padding:48px 0;">
    <div class="product-content__feature-cols" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:24px;" data-reveal>
      <div class="feature-col" style="padding:24px;border:1px solid var(--color-border);border-radius:var(--radius-md);">
        <p style="font-size:28px;font-weight:700;color:var(--color-accent);margin-bottom:8px;">-36dB Peak</p>
        <p style="font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-muted);">Maximum noise reduction</p>
      </div>
      <div class="feature-col" style="padding:24px;border:1px solid var(--color-border);border-radius:var(--radius-md);">
        <p style="font-size:28px;font-weight:700;color:var(--color-accent);margin-bottom:8px;">Personal Fit</p>
        <p style="font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-muted);">4 sizes available</p>
      </div>
      <div class="feature-col" style="padding:24px;border:1px solid var(--color-border);border-radius:var(--radius-md);">
        <p style="font-size:28px;font-weight:700;color:var(--color-accent);margin-bottom:8px;">1–3 Year Lifespan</p>
        <p style="font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-muted);">Washable &amp; reusable</p>
      </div>
    </div>
  </div>

  <div class="container">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'feature_row' %}
          <div class="product-content__feature-row" {{ block.shopify_attributes }} data-reveal>
            {% if block.settings.image %}
              <div class="product-content__feature-img">
                <img src="{{ block.settings.image | img_url: '500x' }}" alt="{{ block.settings.heading }}" loading="lazy">
              </div>
            {% endif %}
            <div class="product-content__feature-text">
              <h2>{{ block.settings.heading }}</h2>
              <p>{{ block.settings.body }}</p>
            </div>
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Product content – Sleeping",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Hero badge",
      "default": "For Better Sleep"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hero heading",
      "default": "Sleep deeper. Wake refreshed."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Hero subheading"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Shop Sleeping Earasers"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "TODO: klant levert main image aan voor Sleeping pagina"
    }
  ],
  "blocks": [
    {
      "type": "feature_row",
      "name": "Feature row",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product content – Sleeping"
    }
  ]
}
{% endschema %}
