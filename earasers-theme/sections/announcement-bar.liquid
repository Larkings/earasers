{% if section.settings.show_bar %}
  <div class="announcement-bar" style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
    <div class="container announcement-bar__inner">
      {% if section.settings.link != blank %}
        <a href="{{ section.settings.link }}" class="announcement-bar__text">{{ section.settings.text }}</a>
      {% else %}
        <p class="announcement-bar__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on orders over \u20ac50 \u00b7 Try risk-free for 30 days"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#E05A4E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
