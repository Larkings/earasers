<!-- ── 6. FAQ ── -->
<div class="container">
  <div class="faq-section" data-reveal>
    <h2 class="faq-section__heading">Frequently Asked Questions</h2>
    {% render 'faq-accordion', question: 'Will I still be able to hear my patients clearly?', answer: 'Yes. The V-filter reduces harmful high-frequency noise (like the handpiece drill) while preserving speech frequencies (250–300 Hz). You can hold a normal conversation without removing them.' %}
    {% render 'faq-accordion', question: 'Are these suitable for hygienists using ultrasonic scalers?', answer: 'Absolutely. The −19 dB Comfort filter is ideal for hygienists — it reduces scaler noise without muffling patient communication. The −26 dB Standard is available for the noisiest procedures.' %}
    {% render 'faq-accordion', question: 'Which filter level do you recommend for dentists?', answer: 'Most dentists use the −19 dB Comfort filter for a full workday. The −26 dB Standard suits the loudest procedures (high-speed handpieces, turbines).' %}
    {% render 'faq-accordion', question: 'Can I wear them all day without discomfort?', answer: 'Yes — medical-grade silicone conforms to your canal shape via body heat. Many dental professionals wear them for full 8-hour workdays without removing them between patients.' %}
    {% render 'faq-accordion', question: 'Is there scientific evidence for hearing damage in dentistry?', answer: 'Yes — multiple independent studies show dental professionals face consistent exposure to noise at damaging levels, primarily from scalers and high-speed handpieces. See the research links on this page.' %}
  </div>
</div>

{% schema %}
{
  "name": "Tandarts — Pagina-inhoud",
  "settings": [
    { "type": "url", "id": "research_url_dutch",   "label": "Link: Nederlandstalig onderzoek" },
    { "type": "url", "id": "research_url_english", "label": "Link: Engelstalig onderzoek" },
    { "type": "url", "id": "research_url_article", "label": "Link: artikel over gehoorschade" }
  ],
  "presets": [{ "name": "Tandarts — Pagina-inhoud" }]
}
{% endschema %}
