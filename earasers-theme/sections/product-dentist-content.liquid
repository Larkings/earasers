{% comment %}
  Layer 2 content for the Dentist & Hygienist product page.
  Hardcoded review cards, testimonials, research links and FAQ.
  Referenced by templates/product.dentist.json
{% endcomment %}

<!-- ── 1. Horizontally scrolling review cards ── -->
<div class="review-cards-scroll" data-reveal>
  <div class="review-cards-scroll__track">
    {% render 'review-cards-scroll',
       image_url: 'https://www.earasers.shop/cdn/shop/files/Matis_Mink_Dentist_2.png',
       quote: 'I depend on clear speech understanding. These earplugs reduce only the damaging frequencies, so I can still hear my assistant and patients perfectly. Our full team uses them now.',
       name: 'Dr. M. Richards',
       year: 2025,
       stars: 5 %}
    {% render 'review-cards-scroll',
       image_url: 'https://www.earasers.shop/cdn/shop/files/Close_Up_Pic_Dentist_74afcccd-2f3c-4178-a73f-b2bf59418973.png',
       quote: 'Very happy with the earplugs. Very comfortable and it made my workday so much more relaxed.',
       name: 'Brummans & Fa Dentists',
       year: 2025,
       stars: 5 %}
    {% render 'review-cards-scroll',
       image_url: 'https://www.earasers.shop/cdn/shop/files/IMG_4654.jpg',
       quote: 'Clear sound, less fatigue. These earplugs take the edge off the high-pitched noise without isolating me from patients.',
       name: 'Dr. A. Vermeer',
       year: 2025,
       stars: 5 %}
    {% render 'review-cards-scroll',
       image_url: 'https://www.earasers.shop/cdn/shop/files/3_05f550b8-2ff8-4b8a-8a28-1ebbbe40fdf4.png',
       quote: 'Lightweight, effective, and easy to wear all day. These earplugs have become part of my daily routine.',
       name: 'Dr. K. Maktur',
       year: 2025,
       stars: 5 %}
    {% render 'review-cards-scroll',
       image_url: 'https://www.earasers.shop/cdn/shop/files/1_9fb6a91f-53c3-40d4-a55d-0a36242d8c78.png',
       quote: 'I never expected earplugs to make such a big difference. I still hear everything clear, but by the end of the day, I feel noticeably more energy.',
       name: 'Dr. Shad Faraj',
       year: 2026,
       stars: 5 %}
  </div>
</div>

<!-- ── 2. Testimonial split: Brummans & Fa ── -->
