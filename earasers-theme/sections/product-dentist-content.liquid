<!-- ── 4. Research / credibility ── -->
<div class="product-content__research-block">
  <div class="container">
    <div class="product-content__research-inner" data-reveal>
      <h2>Research on Hearing Damage in Dentistry</h2>
      <p>Independent studies show that dental professionals face consistent high-frequency noise levels that can lead to long-term hearing loss. These reports outline the data:</p>
      <div class="product-content__research-links">
        {% if section.settings.research_url_dutch != blank %}
          <a href="{{ section.settings.research_url_dutch }}" target="_blank" rel="noopener noreferrer" class="product-content__research-link">→ Dutch Research Publication</a>
        {% else %}
          <span class="product-content__research-link" style="opacity:.4;">→ Dutch Research Publication — URL instellen in editor</span>
        {% endif %}
        {% if section.settings.research_url_english != blank %}
          <a href="{{ section.settings.research_url_english }}" target="_blank" rel="noopener noreferrer" class="product-content__research-link">→ English Research Publication</a>
        {% else %}
          <span class="product-content__research-link" style="opacity:.4;">→ English Research Publication — URL instellen in editor</span>
        {% endif %}
        {% if section.settings.research_url_article != blank %}
          <a href="{{ section.settings.research_url_article }}" target="_blank" rel="noopener noreferrer" class="product-content__research-link">→ The Overlooked Risk of Hearing Loss in Dental Practice</a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

