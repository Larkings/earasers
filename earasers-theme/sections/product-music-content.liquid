{% comment %}
  Layer 2 content for the Music Earplugs product page.
  Hardcoded attenuation chart, comparison table, size guide, musician quotes and FAQ.
  Referenced by templates/product.music.json
{% endcomment %}

<!-- ── 1. Hero image + intro text ── -->
<div class="product-content__hero-section">
  <div class="container" style="padding:64px 0 48px;">
    <div style="text-align:center;max-width:760px;margin:0 auto 40px;" data-reveal>
      <h1 style="font-family:var(--font-display);font-size:clamp(28px,4vw,52px);letter-spacing:.04em;margin-bottom:24px;">Protect your ears, keep your sound</h1>
      <p style="font-size:16px;line-height:1.7;color:var(--color-text-muted);margin-bottom:20px;">Renowned artists such as Franky Rizardo, Paco Osuna, Danny Avila, ANOTR, Stephan Bodzin, Luuk van Dijk, Mason Collective, Toman, Wade, Joey Daniel and many more have enthusiastically embraced these innovative earplugs and are reaping the benefits.</p>
      <p style="font-size:15px;line-height:1.7;font-style:italic;color:var(--color-text-muted);margin-bottom:12px;">&ldquo;I&rsquo;ve found Earasers to be the most comfortable and clear-sounding ear protection I&rsquo;ve used, and throughout my tours, I keep coming back to them.&rdquo; (Franky Rizardo)</p>
      <p style="font-size:15px;line-height:1.7;font-style:italic;color:var(--color-text-muted);margin-bottom:12px;">&ldquo;For comfortable earplugs to play with, I would choose Earasers for sure! Their perfect fit and superior noise reduction make them my top pick for any performance.&rdquo; (WADE)</p>
      <p style="font-size:15px;line-height:1.7;font-style:italic;color:var(--color-text-muted);">&ldquo;As a DJ, clarity is everything. Earasers deliver crystal clear sound while keeping my ears safe - I wouldn&rsquo;t use anything else.&rdquo; (Joey Daniel)</p>
    </div>
    <div class="product-content__hero-img" data-reveal data-delay="1" style="max-width:900px;margin:0 auto;">
      <!-- TODO: Vervang door 'Music Page afbeelding' uit WeTransfer -->
      <img src="{{ section.settings.hero_image | img_url: '900x' | default: 'https://www.earasers.shop/cdn/shop/files/WADE_earasers.webp' }}" alt="Music Earasers" loading="lazy" style="width:100%;border-radius:var(--radius-lg);">
    </div>
  </div>
</div>

<!-- ── 2. Products (collection grid) ── -->
<div class="product-content__chart-section">
  <div class="container">
    <div class="product-content__chart-grid">
      <div data-reveal>
        <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--color-accent);margin-bottom:12px;">Patented Filter Technology</p>
        <h2 style="font-family:var(--font-display);font-size:clamp(24px,3.5vw,44px);letter-spacing:.04em;margin-bottom:16px;">How the filter works</h2>
        <p style="font-size:15px;line-height:1.7;color:var(--color-text-muted);margin-bottom:20px;">The V-filter reduces the most damaging frequencies (around 3,150 Hz) while leaving the natural musical range intact. Unlike flat-attenuating earplugs, Earasers sound clear — not "underwater". You'll hear every note, just safer.</p>
        <ul class="product-content__chart-points">
          <li>Open canal design → no plugged-up feeling</li>
          <li>Medical-grade silicone → custom fit to your ear</li>
          <li>Virtually invisible → no one knows they're in</li>
          <li>Replaceable filter → extend life by swapping just the filter</li>
        </ul>
      </div>
      <div class="product-content__chart-img" data-reveal data-delay="1">
        <img src="{{ section.settings.chart_image | default: 'https://www.earasers.shop/cdn/shop/files/EARASERS_attenuation_tables.png' }}" alt="Earasers attenuation chart" loading="lazy">
      </div>
    </div>
  </div>
</div>

<!-- ── Feature blocks (4 columns) ── -->
<div class="container" style="padding:48px 0;">
  <div class="product-content__feature-cols" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:24px;" data-reveal>
    <div class="feature-col" style="padding:24px;border:1px solid var(--color-border);border-radius:var(--radius-md);">
      <p style="font-size:28px;font-weight:700;color:var(--color-accent);margin-bottom:8px;">100–110dB</p>
      <p style="font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-muted);">Typical booth volume</p>
    </div>
    <div class="feature-col" style="padding:24px;border:1px solid var(--color-border);border-radius:var(--radius-md);">
      <p style="font-size:28px;font-weight:700;color:var(--color-accent);margin-bottom:8px;">-36dB Noise Reduction</p>
      <p style="font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-muted);">Hear your mix</p>
    </div>
    <div class="feature-col" style="padding:24px;border:1px solid var(--color-border);border-radius:var(--radius-md);">
      <p style="font-size:28px;font-weight:700;color:var(--color-accent);margin-bottom:8px;">Personal Fit</p>
      <p style="font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-muted);">4 sizes available</p>
    </div>
    <div class="feature-col" style="padding:24px;border:1px solid var(--color-border);border-radius:var(--radius-md);">
      <p style="font-size:28px;font-weight:700;color:var(--color-accent);margin-bottom:8px;">1–3 Year Lifespan</p>
      <p style="font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-muted);">Washable &amp; reusable</p>
    </div>
  </div>
</div>

<!-- ── 3. Slideshow / scrolling artist images ── -->
<div class="product-content__artist-scroll" style="overflow:hidden;padding:32px 0;background:var(--color-surface);border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);">
  <div style="display:flex;gap:32px;animation:scroll-x 30s linear infinite;width:max-content;">
    <img src="https://www.earasers.shop/cdn/shop/files/WADE_earasers.webp" alt="Wade" style="height:200px;width:auto;object-fit:cover;border-radius:var(--radius-md);">
    <img src="https://www.earasers.shop/cdn/shop/files/Masoncollective.png" alt="Mason Collective" style="height:200px;width:auto;object-fit:cover;border-radius:var(--radius-md);">
    <img src="https://www.earasers.shop/cdn/shop/files/Earasersmodelsinear.png" alt="Franky Rizardo" style="height:200px;width:auto;object-fit:cover;border-radius:var(--radius-md);">
    <img src="https://www.earasers.shop/cdn/shop/files/EARASERS_2024_1.webp" alt="Joey Daniel" style="height:200px;width:auto;object-fit:cover;border-radius:var(--radius-md);">
    <!-- Duplicate for seamless loop -->
    <img src="https://www.earasers.shop/cdn/shop/files/WADE_earasers.webp" alt="Wade" style="height:200px;width:auto;object-fit:cover;border-radius:var(--radius-md);" aria-hidden="true">
    <img src="https://www.earasers.shop/cdn/shop/files/Masoncollective.png" alt="Mason Collective" style="height:200px;width:auto;object-fit:cover;border-radius:var(--radius-md);" aria-hidden="true">
    <img src="https://www.earasers.shop/cdn/shop/files/Earasersmodelsinear.png" alt="Franky Rizardo" style="height:200px;width:auto;object-fit:cover;border-radius:var(--radius-md);" aria-hidden="true">
    <img src="https://www.earasers.shop/cdn/shop/files/EARASERS_2024_1.webp" alt="Joey Daniel" style="height:200px;width:auto;object-fit:cover;border-radius:var(--radius-md);" aria-hidden="true">
  </div>
</div>

<!-- ── Comparison table ── -->
<div class="container" style="padding:64px 0;">
  <div style="text-align:center;max-width:600px;margin:0 auto 40px;" data-reveal>
    <h2 style="font-family:var(--font-display);font-size:clamp(24px,3.5vw,44px);letter-spacing:.04em;margin-bottom:12px;">Earasers vs the alternatives</h2>
    <p style="color:var(--color-text-muted);">Custom moulded earplugs cost €200–400 and take weeks. Earasers give you the same flat-response HiFi protection for €49,95.</p>
  </div>
  <div class="compare-table-wrap" data-reveal>
    <table class="compare-table-full">
      <thead>
        <tr>
          <th></th>
          <th class="col-earasers">Earasers</th>
          <th>Custom Molds</th>
          <th>Budget Plugs</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Price</td><td class="col-earasers">€49,95</td><td>€199+</td><td>€5–15</td></tr>
        <tr><td>Audiologist visit required</td><td class="col-earasers"><span class="cross">✗</span></td><td><span class="check">✓</span></td><td><span class="cross">✗</span></td></tr>
        <tr><td>Delivery</td><td class="col-earasers">2–3 days</td><td>3–6 weeks</td><td>Next day</td></tr>
        <tr><td>Virtually invisible</td><td class="col-earasers"><span class="check">✓</span></td><td><span class="check">✓</span></td><td><span class="cross">✗</span></td></tr>
        <tr><td>Clear, natural sound</td><td class="col-earasers"><span class="check">✓</span></td><td><span class="cross">✗</span></td><td><span class="cross">✗</span></td></tr>
        <tr><td>Replaceable filter</td><td class="col-earasers"><span class="check">✓</span></td><td><span class="cross">✗</span></td><td><span class="cross">✗</span></td></tr>
        <tr><td>Noise reduction</td><td class="col-earasers">-36dB</td><td>-36dB</td><td>Unlike disposable foam, Earasers are washable and long-lasting. The reusable &amp; replaceable sleeves keep them hygienic for months of nightly use.</td></tr>
        <tr><td>Award-winning</td><td class="col-earasers"><span class="check">✓</span></td><td><span class="cross">✗</span></td><td><span class="cross">✗</span></td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- ── Size guide + YouTube embed ── -->
<div class="product-content__size-guide">
  <div class="container">
    <div class="product-content__size-guide-inner" data-reveal>
      <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--color-accent);margin-bottom:12px;">Find Your Fit</p>
      <h2>Not sure which size?</h2>
      <p>Ear canal size doesn't correlate with height, weight or gender. Watch this short video to find your perfect fit:</p>
      <div class="product-content__embed-wrap">
        <iframe src="https://www.youtube.com/embed/Zmj-jJi93q0" title="How to find your Earasers size" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
      </div>
      <p class="product-content__size-note">Still unsure? Order the <strong>Small & Medium combo</strong> — the most popular choice for first-time buyers. 30-day size exchange guaranteed.</p>
    </div>
  </div>
</div>

