<section class="error-404">
  <div class="container error-404__inner">
    <h1 class="error-404__heading">{{ '404.title' | t }}</h1>
    <p class="error-404__sub">{{ '404.subtext' | t }}</p>
    <a href="/" class="btn btn--primary">{{ '404.link' | t }}</a>
  </div>
</section>

{% schema %}
{
  "name": "404"
}
{% endschema %}
