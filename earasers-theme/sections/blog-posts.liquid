{% if section.settings.blog != blank %}
  {% assign blog_obj = blogs[section.settings.blog] %}
  {% if blog_obj.articles_count > 0 %}
    <section class="blog-posts">
      <div class="container">
        <h2 class="blog-posts__heading" data-reveal>{{ section.settings.heading }}</h2>
        <div class="blog-posts__grid">
          {% for article in blog_obj.articles limit: section.settings.post_count %}
            <article class="blog-card" data-reveal data-delay="{{ forloop.index }}">
              {% if article.image %}
                <a href="{{ article.url }}" class="blog-card__img-wrap">
                  <img src="{{ article.image | img_url: '400x250', crop: 'center' }}" alt="{{ article.title }}" class="blog-card__img" loading="lazy" width="400" height="250">
                </a>
              {% endif %}
              <div class="blog-card__body">
                <p class="blog-card__date">{{ article.published_at | date: "%B %d, %Y" }}</p>
                <h3 class="blog-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
                <p class="blog-card__excerpt">{{ article.excerpt | strip_html | truncate: 120 }}</p>
                <a href="{{ article.url }}" class="blog-card__more">Read more →</a>
              </div>
            </article>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Blog posts",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the blog"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "post_count",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Number of posts",
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Blog posts"
    }
  ]
}
{% endschema %}
