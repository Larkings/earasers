<section class="reviews">
  <div class="container">
    <div class="reviews__header">
      <h2 class="reviews__heading" data-reveal>{{ section.settings.heading }}</h2>
      <div class="reviews__score" data-reveal data-delay="1">
        <div class="stars stars--amber">★★★★★</div>
        <span class="reviews__score-text">Rated {{ section.settings.score }}/5 · {{ section.settings.review_count }} verified reviews</span>
        {% if section.settings.show_trustpilot and section.settings.trustpilot_url != blank %}
          <a href="{{ section.settings.trustpilot_url }}" target="_blank" rel="noopener noreferrer" class="reviews__trustpilot">
            View on Trustpilot ↗
          </a>
        {% endif %}
      </div>
    </div>
    <div class="reviews__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'review' %}
            <div class="review-card" {{ block.shopify_attributes }} data-reveal data-delay="{{ forloop.index | modulo: 3 | plus: 1 }}">
              <div class="stars stars--amber">
                {%- assign stars = block.settings.stars -%}
                {%- for i in (1..5) -%}
                  {%- if i <= stars -%}★{%- else -%}<span style="opacity:.25">★</span>{%- endif -%}
                {%- endfor -%}
              </div>
              {% if block.settings.review_title != blank %}
                <p class="review-card__title">{{ block.settings.review_title }}</p>
              {% endif %}
              <p class="review-card__text">&ldquo;{{ block.settings.review_text }}&rdquo;</p>
              <div class="review-card__footer">
                <p class="review-card__reviewer">{{ block.settings.country }} · {{ block.settings.reviewer_name }}</p>
                <div class="review-card__avatar">
                  {% if block.settings.reviewer_image != blank %}
                    <img src="{{ block.settings.reviewer_image }}" alt="{{ block.settings.reviewer_name }}" class="review-card__avatar-img" width="48" height="48" loading="lazy">
                  {% else %}
                    <span class="review-card__avatar-initial">{{ block.settings.reviewer_name | slice: 0 | upcase }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Sectiekop", "default": "Our customers tell it better than we do!" },
    { "type": "text", "id": "score", "label": "Score (bv. 4.7)", "default": "4.7" },
    { "type": "text", "id": "review_count", "label": "Aantal reviews (bv. 1000+)", "default": "1000+" },
    { "type": "checkbox", "id": "show_trustpilot", "label": "Trustpilot badge tonen", "default": true },
    { "type": "url", "id": "trustpilot_url", "label": "Trustpilot link" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "reviewer_name", "label": "Naam reviewer", "default": "Saskia H." },
        { "type": "text", "id": "country", "label": "Landcode (bv. NL, GB)", "default": "NL" },
        { "type": "range", "id": "stars", "label": "Sterren", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "review_title", "label": "Reviewtitel (optioneel)" },
        { "type": "textarea", "id": "review_text", "label": "Reviewtekst", "default": "These are absolutely brilliant." },
        { "type": "text", "id": "reviewer_image", "label": "Foto reviewer URL (optioneel)", "info": "Gebruik een CDN URL van Shopify Files — bv. https://www.earasers.shop/cdn/shop/files/..." }
      ]
    }
  ],
  "presets": [{ "name": "Reviews" }]
}
{% endschema %}
