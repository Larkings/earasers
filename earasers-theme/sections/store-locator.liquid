<section class="store-locator">
  <div class="container">
    <h1 class="store-locator__heading" data-reveal>{{ section.settings.heading }}</h1>
    {% if section.settings.subheading != blank %}
      <p class="store-locator__sub" data-reveal data-delay="1">{{ section.settings.subheading }}</p>
    {% endif %}

    <!-- Search bar -->
    <div class="store-locator__search" data-reveal>
      <input type="text" id="store-search" class="store-locator__input" placeholder="Search by city or postcode..." oninput="filterStores(this.value)">
      <svg class="store-locator__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </div>

    <!-- Store grid -->
    <div class="store-locator__grid" id="store-grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'store' %}
            <div class="store-card" data-city="{{ block.settings.city | downcase }}" data-postcode="{{ block.settings.postcode | downcase }}" data-country="{{ block.settings.country }}" {{ block.shopify_attributes }} data-reveal>
              {% if block.settings.badge != blank %}
                <span class="store-card__badge">{{ block.settings.badge }}</span>
              {% endif %}
              <h3 class="store-card__name">{{ block.settings.name }}</h3>
              <p class="store-card__address">
                {{ block.settings.address }}<br>
                {{ block.settings.postcode }} {{ block.settings.city }}<br>
                {{ block.settings.country }}
              </p>
              {% if block.settings.hours != blank %}
                <p class="store-card__hours">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {{ block.settings.hours }}
                </p>
              {% endif %}
              {% if block.settings.phone != blank %}
                <p class="store-card__phone">
                  <a href="tel:{{ block.settings.phone }}">{{ block.settings.phone }}</a>
                </p>
              {% endif %}
              <div class="store-card__links">
                {% if block.settings.website != blank %}
                  <a href="{{ block.settings.website }}" target="_blank" rel="noopener noreferrer" class="store-card__link">Visit website →</a>
                {% endif %}
                {% if block.settings.maps_url != blank %}
                  <a href="{{ block.settings.maps_url }}" target="_blank" rel="noopener noreferrer" class="store-card__map">Get directions →</a>
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    <p class="store-locator__no-results" id="no-results" hidden>{{ section.settings.no_results_text }}</p>

    <!-- Online CTA -->
    <div class="store-locator__cta" data-reveal>
      <h2 class="store-locator__cta-heading">{{ section.settings.cta_heading }}</h2>
      <p class="store-locator__cta-sub">{{ section.settings.cta_subtext }}</p>
      <a href="/collections/all" class="btn btn--primary">Shop online →</a>
    </div>

    <!-- Retailer section -->
    {% if section.settings.retailer_heading != blank %}
      <div class="store-locator__retailer" data-reveal>
        <h2 class="store-locator__retailer-heading">{{ section.settings.retailer_heading }}</h2>
        <p class="store-locator__retailer-text">{{ section.settings.retailer_text }}</p>
        <a href="mailto:info@earasers.shop" class="btn btn--outline">Become a retailer →</a>
      </div>
    {% endif %}
  </div>
</section>

<script>
function filterStores(query) {
  const q = query.toLowerCase().trim();
  const cards = document.querySelectorAll('#store-grid .store-card');
  let visible = 0;
  cards.forEach(card => {
    const match = !q || card.dataset.city.includes(q) || card.dataset.postcode.includes(q) || card.dataset.country.toLowerCase().includes(q) || card.querySelector('.store-card__name').textContent.toLowerCase().includes(q);
    card.style.display = match ? '' : 'none';
    if (match) visible++;
  });
  const noResults = document.getElementById('no-results');
  if (noResults) noResults.hidden = visible > 0;
}
</script>

{% schema %}
{
  "name": "Store Locator",
  "settings": [
    { "type": "text", "id": "heading", "label": "Paginakop", "default": "Store Locator" },
    { "type": "text", "id": "subheading", "label": "Ondertitel", "default": "Find Earasers near you — or order online with free shipping from €39." },
