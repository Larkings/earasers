<section class="reviews">
  <div class="container">
    <div class="reviews__header">
      <h2 class="reviews__heading" data-reveal>{{ section.settings.heading }}</h2>
      <div class="reviews__score" data-reveal data-delay="1">
        <div class="stars">★★★★★</div>
        <span class="reviews__score-text">{{ section.settings.score_text }}</span>
        {% if section.settings.trustpilot_url != blank %}
          <a href="{{ section.settings.trustpilot_url }}" target="_blank" rel="noopener noreferrer" class="reviews__trustpilot">
            View on Trustpilot ↗
          </a>
        {% endif %}
      </div>
    </div>
    <div class="reviews__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'review' %}
            <div class="review-card" {{ block.shopify_attributes }} data-reveal data-delay="{{ forloop.index | modulo: 3 | plus: 1 }}">
              <div class="stars stars--amber">
                {%- assign stars = block.settings.rating -%}
                {%- for i in (1..5) -%}
                  {%- if i <= stars -%}★{%- else -%}<span style="opacity:.25">★</span>{%- endif -%}
                {%- endfor -%}
              </div>
              <p class="review-card__text">&ldquo;{{ block.settings.text }}&rdquo;</p>
              <div class="review-card__footer">
                <p class="review-card__reviewer">{{ block.settings.country }} · {{ block.settings.name }}</p>
                <div class="review-card__avatar">
                  {% if block.settings.photo %}
                    <img src="{{ block.settings.photo }}" alt="{{ block.settings.name }}" class="review-card__avatar-img" width="48" height="48" loading="lazy">
                  {% else %}
                    <span class="review-card__avatar-initial">{{ block.settings.name | slice: 0 | upcase }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real people. Real opinions."
    },
    {
      "type": "text",
      "id": "score_text",
      "label": "Score text",
      "default": "Rated 4.7 out of 5 by over 1,000 customers"
    },
    {
      "type": "url",
      "id": "trustpilot_url",
      "label": "Trustpilot URL"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "Jane D."
        },
        {
          "type": "text",
          "id": "country",
          "label": "Country code",
          "default": "NL"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "These are absolutely brilliant."
        },
        {
          "type": "text",
          "id": "photo",
          "label": "Photo URL (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review", "settings": { "name": "Saskia H.", "country": "NL", "rating": 5, "text": "Veel beter en goedkoper dan alle op maat gemaakte oortjes van gevestigde merken die ik gehad heb!" } },
        { "type": "review", "settings": { "name": "Michael T.", "country": "GB", "rating": 5, "text": "These are perfect. They fit in very nicely, are barely visible, and balance the sound beautifully." } },
        { "type": "review", "settings": { "name": "Joanne C.", "country": "GB", "rating": 5, "text": "Great customer service. They sent me the mediums plus the filter removal tool free of charge!" } }
      ]
    }
  ]
}
{% endschema %}
