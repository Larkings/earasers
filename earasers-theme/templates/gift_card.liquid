{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ 'Gift card' }} &ndash; {{ shop.name }}</title>
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
</head>
<body class="gift-card-page">
  <div class="container" style="padding: 60px 20px; text-align: center;">
    <h1>{{ shop.name }}</h1>
    <h2>Gift Card</h2>

    {% assign gift_card = gift_card %}
    <div class="gift-card">
      <img src="{{ 'gift-card.png' | asset_url }}" alt="Gift card" onerror="this.style.display='none'">
      <p class="gift-card__amount">
        {% if gift_card.balance != gift_card.initial_value %}
          <span>{{ gift_card.balance | money }}</span> remaining of
        {% endif %}
        <strong>{{ gift_card.initial_value | money }}</strong>
      </p>
      <div class="gift-card__code">
        <p>Your gift card code:</p>
        <strong id="GiftCardDigits">{{ gift_card.code | format_code }}</strong>
      </div>

      {% if gift_card.expired or gift_card.enabled == false %}
        <p class="gift-card__expired">This gift card has expired.</p>
      {% else %}
        <p>Expires {{ gift_card.expires_on | date: "%B %d, %Y" }}</p>
      {% endif %}

      <a href="{{ shop.url }}" class="btn btn--primary">Continue shopping</a>
    </div>
  </div>
</body>
</html>
