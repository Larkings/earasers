<div class="customer-form">
  <div class="container">
    <h1>Create account</h1>
    {% form 'create_customer' %}
      {{ form.errors | default_errors }}
      <div class="form-field">
        <label for="first_name">First name</label>
        <input type="text" name="customer[first_name]" id="first_name" class="input" autocomplete="given-name">
      </div>
      <div class="form-field">
        <label for="last_name">Last name</label>
        <input type="text" name="customer[last_name]" id="last_name" class="input" autocomplete="family-name">
      </div>
      <div class="form-field">
        <label for="email">Email</label>
        <input type="email" name="customer[email]" id="email" class="input" autocomplete="email" required>
      </div>
      <div class="form-field">
        <label for="password">Password</label>
        <input type="password" name="customer[password]" id="password" class="input" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn btn--primary">Create account</button>
    {% endform %}
    <p>Already have an account? <a href="{{ routes.account_login_url }}">Sign in</a></p>
  </div>
</div>
