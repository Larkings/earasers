<div class="customer-form">
  <div class="container">
    <h1>Login</h1>
    {% form 'customer_login' %}
      {{ form.errors | default_errors }}
      <div class="form-field">
        <label for="email">Email</label>
        <input type="email" name="customer[email]" id="email" class="input" autocomplete="email" required>
      </div>
      <div class="form-field">
        <label for="password">Password</label>
        <input type="password" name="customer[password]" id="password" class="input" autocomplete="current-password" required>
      </div>
      <button type="submit" class="btn btn--primary">Sign in</button>
      <p><a href="{{ routes.account_recover_url }}">Forgot your password?</a></p>
    {% endform %}
    <p>New customer? <a href="{{ routes.account_register_url }}">Create account</a></p>
  </div>
</div>
